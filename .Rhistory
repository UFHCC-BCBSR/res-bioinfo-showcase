# Node attributes
node [shape = box, style = filled, fillcolor = lightblue,
fontname = Arial, fontsize = 11, width = 2.5, height = 1.2]
# Define nodes with HTML-like labels for bold titles
A [label = <<B>Guided Selection</B><BR/><BR/>Study design questions<BR/>Tissue type<BR/>Technical parameters>]
B [label = <<B>Select &amp; Run</B><BR/><BR/>Up to 5 algorithms<BR/>1 reference dataset<BR/>Parallel execution>]
