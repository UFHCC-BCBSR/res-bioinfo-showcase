fontname = Arial, fontsize = 12, width = 2.5, height = 1.2]
# Define nodes
A [label = 'Guided Selection\n\nStudy design questions\nTissue type\nTechnical parameters']
B [label = 'Select & Run\n\nUp to 5 algorithms\n1 reference dataset\nParallel execution']
C [label = 'Evaluate Results\n\nCompare using RMSRD\nVisualize in UI\nPer-cell-type differences']
D [label = 'Export\n\nSelected results\nAnnotation CSV\nBarcode data']
# Define edges
A -> B -> C -> D
}
")
