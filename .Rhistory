D [label = <<B>Export</B><BR/><BR/>Selected results<BR/>Annotation CSV<BR/>Barcode data>]
# Create ranks for 2x2 layout
{rank = same; A; B}
{rank = same; C; D}
# Define edges
A -> B
A -> C [weight = 2]
B -> D [weight = 2]
C -> D
}
")
