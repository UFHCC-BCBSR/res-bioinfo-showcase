graph [layout = dot, rankdir = TB, fontname = Arial]
# Node attributes
node [shape = box, style = filled, fillcolor = '#B3D9E8',
color = '#003366', penwidth = 2,
fontname = Arial, fontsize = 11, width = 2.5, height = 1.2]
# Define nodes
A [label = <<B><FONT COLOR='#D2492A'>Guided Selection</FONT></B><BR/><BR/><FONT COLOR='#003366'>Study design questions<BR/>Tissue type<BR/>Technical parameters</FONT>>]
B [label = <<B><FONT COLOR='#D2492A'>Select &amp; Run</FONT></B><BR/><BR/><FONT COLOR='#003366'>Up to 5 algorithms<BR/>1 reference dataset<BR/>Parallel execution</FONT>>]
C [label = <<B><FONT COLOR='#D2492A'>Evaluate Results</FONT></B><BR/><BR/><FONT COLOR='#003366'>Compare using RMSRD<BR/>Visualize in UI<BR/>Per-cell-type differences</FONT>>]
D [label = <<B><FONT COLOR='#D2492A'>Export</FONT></B><BR/><BR/><FONT COLOR='#003366'>Selected results<BR/>Annotation CSV<BR/>Barcode data</FONT>>]
# Create 2x2 layout
{rank = same; A; B}
{rank = same; C; D}
# Invisible edges to force structure
A -> B [style = invis]
A -> C [style = invis]
B -> D [style = invis]
C -> D [style = invis]
}
")
# Export as high-res PNG (300 DPI equivalent)
diagram %>%
export_svg() %>%
charToRaw() %>%
rsvg_png("flowchart.png", width = 3000, height = 2000)
